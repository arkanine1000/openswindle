# OpenRouter credentials (https://openrouter.ai) — required unless mock mode is on
OPENROUTER_API_KEY=

# OpenRouter model slug
OPENSWINDLE_LLM_MODEL=deepseek/deepseek-v4-flash

# Bypass the LLM entirely and use the deterministic scripted policy (no API key needed)
OPENSWINDLE_MOCK_LLM=false

# Reprompt budget for invalid/illegal LLM outputs before the scripted fallback
OPENSWINDLE_LLM_MAX_REPROMPTS=2

# JSON object merged into every LLM request (provider extras). Example: disable
# provider reasoning/thinking via OpenRouter's unified control:
# OPENSWINDLE_LLM_EXTRA_BODY={"reasoning": {"effort": "none"}}
OPENSWINDLE_LLM_EXTRA_BODY=

# CORS origins for the frontend dev server (comma-separated)
OPENSWINDLE_CORS_ORIGINS=http://localhost:5173

# In-memory retention for finished matches (active matches are never pruned)
OPENSWINDLE_FINISHED_MATCH_TTL_SECONDS=3600
OPENSWINDLE_MAX_FINISHED_MATCHES=1000
