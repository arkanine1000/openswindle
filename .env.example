# Vercel AI Gateway key (https://vercel.com/docs/ai-gateway) — required unless mock mode is on
VERCEL_AI_GATEWAY_API_KEY=

# LiteLLM model string routed through the gateway
OPENSWINDLE_LLM_MODEL=vercel_ai_gateway/deepseek/deepseek-v4-flash

# Bypass the LLM entirely and use the deterministic scripted policy (no API key needed)
OPENSWINDLE_MOCK_LLM=false

# Reprompt budget for illegal/unparseable LLM outputs before the scripted fallback
OPENSWINDLE_LLM_MAX_REPROMPTS=2

# JSON object merged into every LLM request (provider extras). Example: disable
# provider thinking mode for faster, cheaper turns:
# OPENSWINDLE_LLM_EXTRA_BODY={"thinking": {"type": "disabled"}}
OPENSWINDLE_LLM_EXTRA_BODY=

# Models whose provider rejects response_format (JSON mode skipped up front)
OPENSWINDLE_JSON_MODE_UNSUPPORTED_MODELS=vercel_ai_gateway/deepseek/deepseek-v4-flash

# CORS origins for the frontend dev server (comma-separated)
OPENSWINDLE_CORS_ORIGINS=http://localhost:5173

# In-memory retention for finished matches (active matches are never pruned)
OPENSWINDLE_FINISHED_MATCH_TTL_SECONDS=3600
OPENSWINDLE_MAX_FINISHED_MATCHES=1000
